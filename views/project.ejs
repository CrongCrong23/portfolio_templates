<%- include('partials/header', { title: project.title }) %>

<article class="project-detail">
    <header class="project-hero float-up">
        <div class="project-hero-content">
            <span class="project-category"><%= project.category %></span>
            <h1><%= project.title %></h1>
            <p class="project-lead"><%= project.shortDescription %></p>
        </div>
        <div class="project-hero-image-wrapper glass-card">
            <img src="<%= project.heroImage %>" alt="<%= project.title %> Hero Image" class="project-hero-image">
        </div>
    </header>

    <div class="project-body section">
        <div class="project-meta float-up-delay">
            <div class="meta-item">
                <h4>Role</h4>
                <p><%= project.role %></p>
            </div>
            <div class="meta-item">
                <h4>Tech Stack</h4>
                <div class="tech-tags">
                    <% project.techStack.forEach(tech => { %>
                        <span class="tech-tag"><%= tech %></span>
                    <% }) %>
                </div>
            </div>
        </div>

        <div class="project-description float-up">
            <h2>About the Project</h2>
            <p><%= project.fullDescription %></p>
        </div>

        <div class="project-gallery float-up">
            <h2>Gallery</h2>
            <div class="gallery-grid">
                <% project.gallery.forEach(img => { %>
                    <div class="gallery-item glass-card">
                        <img src="<%= img %>" alt="Gallery Image">
                    </div>
                <% }) %>
            </div>
        </div>
        
        <div class="project-nav float-up">
            <a href="/#work" class="btn btn-secondary">← Back to Portfolio</a>
        </div>
    </div>
</article>

<%- include('partials/footer') %>
