<%- include('partials/header') %>

<section id="hero" class="hero section">
    <div class="hero-content float-up">
        <div class="badge">Premium Templates</div>
        <h1>Launch your freelance career with <span class="highlight">weightless design.</span></h1>
        <p>I craft premium, high-performing web portfolio templates for freelancers and agencies. Stand out from the crowd with clean aesthetics and seamless user experiences.</p>
        <div class="hero-actions">
            <a href="#templates" class="btn btn-primary">Browse Templates</a>
        </div>
    </div>
    <div class="hero-image float-up-delay">
        <div class="avatar-container">
            <img src="/assets/avatar.png" alt="Template Creator" class="avatar float-anim">
            <div class="glass-card stat-card stat-1 float-anim-alt">
                <span class="stat-number">3+</span>
                <span class="stat-label">Premium Themes</span>
            </div>
            <div class="glass-card stat-card stat-2 float-anim">
                <span class="stat-number">5k+</span>
                <span class="stat-label">Happy Creators</span>
            </div>
        </div>
    </div>
</section>

<section id="templates" class="work section">
    <div class="section-header float-up">
        <h2>Browse Templates</h2>
        <p>Find the perfect design for your next portfolio.</p>
    </div>
    <div class="work-grid">
        <% templates.forEach((template, index) => { %>
            <a href="/template/<%= template.id %>" class="glass-card project-card float-up" style="transition-delay: <%= index * 0.1 %>s; display: block; text-decoration: none; color: inherit;">
                <div class="project-image-wrapper">
                    <img src="<%= template.thumbnail %>" alt="<%= template.title %> Preview" class="project-image">
                </div>
                <div class="project-info">
                    <span class="project-category"><%= template.category %></span>
                    <h3><%= template.title %></h3>
                    <p><%= template.shortDescription %></p>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 1.5rem;">
                        <span class="project-link" style="margin-top: 0;">View Details →</span>
                        <span style="font-weight: 600; font-size: 1.1rem; color: var(--text-main);"><%= template.price %></span>
                    </div>
                </div>
            </a>
        <% }) %>
    </div>
</section>

<section id="contact" class="contact section">
    <div class="glass-card contact-card float-up">
        <div class="contact-content">
            <h2>Need a custom design?</h2>
            <p>I also take on freelance clients for fully bespoke portfolio websites.</p>
            
            <form id="contactForm" class="contact-form">
                <div class="form-group">
                    <input type="text" id="name" name="name" placeholder="Your Name" required class="form-control">
                </div>
                <div class="form-group">
                    <input type="email" id="email" name="email" placeholder="Your Email" required class="form-control">
                </div>
                <div class="form-group">
                    <textarea id="message" name="message" placeholder="Tell me about your project..." required class="form-control" rows="4"></textarea>
                </div>
                <button type="submit" class="btn btn-primary lg w-100" id="submitBtn">Request Custom Quote</button>
                <div id="formMessage" class="form-message"></div>
            </form>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
